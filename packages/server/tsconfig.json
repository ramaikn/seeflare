{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "paths": {
      "~/*": ["./app/*"]
    },
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "sourceMap": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "target": "ES2022",
    "strict": true,
    "allowJs": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "noEmit": true,
    "skipLibCheck": true
  }
}