{
    "main": "./workers/app.ts",
    "name": "counterscale",
    "compatibility_flags": ["nodejs_compat_v2"],
    "compatibility_date": "2024-12-13",
    "assets": {
        "binding": "ASSETS",
        "directory": "./build/client"
    },
    "analytics_engine_datasets": [
        {
            "binding": "WEB_COUNTER_AE",
            "dataset": "metricsDataset"
        }
    ],
    "r2_buckets": [
        {
            "bucket_name": "counterscale-daily-rollups",
            "preview_bucket_name": "counterscale-daily-rollups-dev",
            "binding": "DAILY_ROLLUPS"
        }
    ],
    "d1_databases": [
        {
            "binding": "ANALYTICS_DB",
            "database_name": "seeflare-analytics",
            "database_id": "7b989900-d0c1-4f62-8ff1-921125378fed"
        }
    ],
    "triggers": {
        "crons": [
            "0 2 * * *"
        ]
    }
}
